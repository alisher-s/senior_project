# Copy to ".env" in this directory (see .gitignore). Docker Compose loads ".env" here
# automatically and substitutes these values into docker-compose.yml for the api service.
# Do not commit ".env" or put real passwords in tracked files.

SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_PASSWORD=

# MinIO / S3-compatible object storage for event cover images (public read bucket).
# Public image URLs are formed as: ${MINIO_PUBLIC_URL}/${MINIO_BUCKET}/${objectName}
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=event-assets
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000
