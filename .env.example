# Copy this file to ".env" and fill in your values.
# Docker Compose loads ".env" automatically. Do NOT commit ".env" with real secrets.

# ── SMTP (email notifications) ───────────────────────────────────────────────
# Leave SMTP_HOST empty to disable email (no-op sender — app still runs fine).
#
# Option A: Gmail App Password
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords → create one
#   3. Fill in your Gmail address and the 16-char App Password below
#
# Option B: Mailtrap (free sandbox — emails never reach real inboxes)
#   Sign up at mailtrap.io → Email Testing → SMTP Settings → copy credentials

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_FROM=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# ── Stripe payments ───────────────────────────────────────────────────────────
# Leave STRIPE_SECRET_KEY empty to run without payments (all pay endpoints → 501).
# Each person needs their OWN Stripe test account — keys are account-specific.
#
# How to get your keys:
#   1. Sign up free at dashboard.stripe.com (test mode, no real money)
#   2. Developers → API Keys → copy "Secret key" (starts with sk_test_...)
#   3. Install Stripe CLI: https://stripe.com/docs/stripe-cli
#   4. Run: stripe listen --forward-to localhost:8080/api/v1/payments/stripe/webhook
#   5. Copy the "whsec_..." key it prints → paste as STRIPE_WEBHOOK_SECRET
#   6. Restart docker compose after setting both keys

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_SUCCESS_URL=http://localhost:8080/payment-success
STRIPE_CANCEL_URL=http://localhost:8080/payment-cancel

# ── JWT & webhook secrets (change in production) ─────────────────────────────
# In APP_ENV=development these have safe defaults; override for any shared env.
# JWT_ACCESS_SECRET=change_me_in_production
# JWT_REFRESH_SECRET=change_me_in_production
# PAYMENTS_WEBHOOK_SECRET=change_me_in_production
