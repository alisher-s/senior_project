# Copy to ".env" in this directory (see .gitignore). Docker Compose loads ".env" here
# automatically and substitutes these values into docker-compose.yml for the api service.
# Do not commit ".env" or put real passwords in tracked files.

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_FROM=
SMTP_PASSWORD=

# MinIO / S3-compatible object storage for event cover images (public read bucket).
# Public image URLs are formed as: ${MINIO_PUBLIC_URL}/${MINIO_BUCKET}/${objectName}
#
# If you run the API via docker compose, MINIO_ENDPOINT must be reachable from inside the `api` container.
# Use `minio:9000` (Compose service DNS). If you run the API on your host machine, use `localhost:9000`.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=event-assets
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000
# On API startup, upload repo `static/` into the bucket if the folder exists (Docker: copied to /home/app/static).
# Set to false to disable. Override directory with MINIO_STATIC_SEED_DIR.
# MINIO_SEED_STATIC=true
# MINIO_STATIC_SEED_DIR=/path/to/static
