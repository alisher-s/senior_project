APP_ENV=development
PORT=8080

# IMPORTANT: use real secrets in production.
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_ISSUER=nu-ticketing
JWT_AUDIENCE=nu-ticketing-client

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
POSTGRES_SSLMODE=disable

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

AUTH_NU_EMAIL_DOMAIN=nu.edu.kz
AUTH_BCRYPT_COST=12

# Payment provider webhook signature verification (HMAC-SHA256 over raw JSON body).
PAYMENTS_WEBHOOK_SECRET=dev_payments_webhook_secret_change_me

# SMTP (notifications email worker). If SMTP_HOST is empty, the worker uses a no-op sender (no network).
# Mailtrap Email Testing: host sandbox.smtp.mailtrap.io — prefer port 587 (STARTTLS); use 2525 only if your network allows it.
# PLAIN auth username: set SMTP_FROM to your Mailtrap inbox SMTP username (see provider SMTP settings).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_FROM=
SMTP_PASSWORD=

